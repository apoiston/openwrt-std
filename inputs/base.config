CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_USE_MOLD=y
CONFIG_JSON_CYCLONEDX_SBOM=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_rpcd-mod-rpcsys=y

CONFIG_TARGET_ROOTFS_EROFS=y
CONFIG_TARGET_EROFS_PCLUSTER_SIZE=256
CONFIG_KERNEL_EROFS_FS=y
CONFIG_KERNEL_EROFS_FS_ZIP=y
CONFIG_KERNEL_EROFS_FS_ZIP_LZMA=y

CONFIG_PACKAGE_open-vm-tools=y
CONFIG_PACKAGE_kmod-vmxnet3=y

CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_yq=y

CONFIG_PACKAGE_zoneinfo-core=y
CONFIG_PACKAGE_zoneinfo-asia=y

CONFIG_PACKAGE_htop=y
CONFIG_HTOP_LMSENSORS=y

CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_swap-utils=y
CONFIG_PACKAGE_shadow-utils=y
CONFIG_PACKAGE_ntfs-3g=y

# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ip-full=y

CONFIG_PACKAGE_luci-nginx=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

CONFIG_PACKAGE_nginx-full=y
CONFIG_PACKAGE_nginx-ssl-util=y
CONFIG_PACKAGE_nginx-mod-luci=y
CONFIG_PACKAGE_nginx-mod-ubus=y
CONFIG_PACKAGE_nginx-mod-stream=y
CONFIG_PACKAGE_nginx-mod-headers-more=y
CONFIG_PACKAGE_nginx-mod-brotli=y
CONFIG_PACKAGE_nginx-mod-dav-ext=y

CONFIG_PACKAGE_uwsgi=y
CONFIG_PACKAGE_uwsgi-luci-support=y
CONFIG_PACKAGE_uwsgi-cgi-plugin=y
CONFIG_PACKAGE_uwsgi-syslog-plugin=y

CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_nikki=y
CONFIG_PACKAGE_mihomo-alpha=y
# CONFIG_PACKAGE_mihomo-meta is not set

CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_openssh-sftp-server=y

CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-utils=y

CONFIG_PACKAGE_nfs-kernel-server-utils=y
CONFIG_PACKAGE_nfs-kernel-server-v4=y
CONFIG_PACKAGE_nfs-utils-v4=y

CONFIG_PACKAGE_rsync=y
CONFIG_PACKAGE_rsyncd=y
CONFIG_PACKAGE_libxxhash=y
CONFIG_RSYNC_xxhash=y
